# OS / editor
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Local working files and backups
*.tmp
*.temp
*.bak
*.autosave
~$*.xlsx

# Local exported packages
# .shjpatch 文件默认忽略，但 submissions 目录中的正式提交包允许进入仓库
*.shjpatch
!submissions/**/*.shjpatch
*.shjdata

# Secrets: never commit
.env
.env.*
*.key
*.pem
