# OS / editor
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Local working files and backups
*.tmp
*.temp
*.bak
*.autosave
~$*.xlsx

# Exported packages are ignored by default, except the formal submissions folders
*.shjpatch
*.shjdata
!submissions/**/*.shjpatch
!submissions/**/*.shjdata

# Secrets: never commit
.env
.env.*
*.key
*.pem
