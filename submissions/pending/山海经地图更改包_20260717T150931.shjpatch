          "profile": {
            "regionPosition": "海内南方山地区域",
            "oneLineSummary": "苍梧之山是一座位于南方地带的神圣山脉，其核心意义在于它是上古两大帝王舜与丹朱的安息之所，地位极度崇高。",
            "briefSummary": "苍梧之山是一座位于南方地带的神圣山脉，其核心意义在于它是上古两大帝王舜与丹朱的安息之所，地位极度崇高。",
            "basicSummary": "海内南方山地区域",
            "localTags": "双帝陵寝 / 帝舜葬阳 / 丹朱葬阴 / 海内南方 / 帝陵神山",
            "tileType": "山地",
            "hydrology": "原文未载明确（地图推定临近湘水及赤水）",
