        "dossier": {
          "format": "nine-section-v2",
          "sourceFile": "井群(昆仑神山上的特殊设施).md",
          "sourceFiles": [
            "井群(昆仑神山上的特殊设施).md"
          ],
          "profile": {
            "regionPosition": "海内西北昆仑之虚区域",
            "oneLineSummary": "此地为昆仑神山上的特殊水系设施，由多口水井组成，外部皆设有珍贵的玉石栏杆，彰显神域之尊贵。",
            "briefSummary": "此地为昆仑神山上的特殊水系设施，由多口水井组成，外部皆设有珍贵的玉石栏杆，彰显神域之尊贵。",
            "basicSummary": "海内西北昆仑之虚区域",
            "localTags": "昆仑之虚、九井、玉石井槛、海内西经、神山水系、内部设施",
            "tileType": "井群 / 内部设施",
            "hydrology": "昆仑山上水文网",
            "orientation": "海内西北昆仑之虚",
            "sourceCitation": "《山海经·海内西经》",
            "parentRegion": "海内西经",
            "adjacentTiles": "木禾、九门",
            "relatedWaters": "九井",
            "relatedLife": "开明兽（镇守外围）、百神（居于此山）",
            "tileOriginalExcerpt": "“海内昆仑之虚，在西北，帝之下都。……面有九井，以玉为槛。”（出自《山海经·海内西经》）",
            "otherAllusions": "《淮南子·地形训》亦记载：“昆仑之丘……有九重，有九井。”古注多将此视为昆仑神山作为“帝之下都”的标准配置，彰显仙家神域的秩序与高洁。",
            "detailedSummary": "结合地块属性与本地标签，“井群／内部设施”明确指向海内西北昆仑之虚上的“九井”。作为“帝之下都”的核心水文与建筑设施，这九口井分布于神山的不同方位。原典中虽未记载井中具体的生灵或独立生长的草木，但极其罕见地强调了其建筑材质——“以玉为槛”，即用珍稀玉石砌成井栏。这种高规格的矿物应用，将水系自然属性与神圣人造设施完美结合，凸显了昆仑虚作为百神所在地与庄严，构成了荒外神圣空间内极具秩序感的人文与地理景观。",
            "geoEnvironment": "海内西北昆仑之虚区域\n井群 / 内部设施\n昆仑山上水文网",
            "evidenceChain": "《山海经·海内西经》\n《淮南子·地形训》亦记载：“昆仑之丘……有九重，有九井。”古注多将此视为昆仑神山作为“帝之下都”的标准配置，彰显仙家神域的秩序与高洁。"
          },
