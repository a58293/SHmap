        "dossier": {
          "format": "nine-section-v1",
          "sourceFile": "孟涂之所.md",
          "sourceFiles": [
            "孟涂之所.md"
          ],
          "profile": {
            "regionPosition": "海内南方区域（原文直载）",
            "oneLineSummary": "位于丹山以西的山上，是夏启之臣孟涂治理巴地并决断神明与巴人诉讼的神圣法庭。",
            "briefSummary": "位于丹山以西的山上，是夏启之臣孟涂治理巴地并决断神明与巴人诉讼的神圣法庭。",
            "basicSummary": "海内南方区域（原文直载）",
            "localTags": "海内南经、孟涂法庭、巴地之上、丹山之西、神明诉讼、血衣神判、记录极简",
            "tileOriginalExcerpt": "“夏后启之臣曰孟涂，是司神于巴。巴人讼于孟涂之所，其衣有血者乃无辜。是请在山上，在丹山西。”出自《山海经·海内南经》（原文直载）。",
            "otherAllusions": "晋代郭璞注：“言孟涂神在巴，巴人有狱讼，决之于孟涂也……神为理直者致血于衣上以为信也。”（古注补充）。后世地方志多附会于夔州（今奉节）一带，但在原典中仅作南方神迹的独立地理坐标。",
            "detailedSummary": "结合地块属性与数据关系，“孟涂之所”是《山海经·海内南经》中一处罕见的神权与司法交织的遗迹型地块。在空间坐标上，它明确被锚定于“丹山”的正西方，建构在巴地的一座山上（原文直载）。原典对该山及其周边的自然植被、水网走势与鸟兽分布皆采取了极度克制的留白，却将笔墨全部聚焦于独特的“事件”机制——这里是夏启之臣孟涂治理巴地神明与百姓的法庭。巴人在此聚讼，以衣服上是否显现血迹来进行神判。这种彻底剥离环境渲染、用神秘事件直接定义空间属性的记录方式，生动保留了南方原始宗教决狱的神异氛围，非常适合作为您构建“南方神明人物拓扑模块”时核心的叙事与地理交互基点。",
            "geoEnvironment": "海内南方区域（原文直载）\n山地/遗迹（原文直载：居在山上）\n未载（原文未载）",
            "evidenceChain": "《山海经·海内南经》（原文直载）\n晋代郭璞注：“言孟涂神在巴，巴人有狱讼，决之于孟涂也……神为理直者致血于衣上以为信也。”（古注补充）。后世地方志多附会于夔州（今奉节）一带，但在原典中仅作南方神迹的独立地理坐标。",
            "tileType": "山地/遗迹（原文直载：居在山上）",
            "hydrology": "未载（原文未载）",
            "orientation": "丹山以西（原文直载：在丹山西）",
            "sourceCitation": "《山海经·海内南经》（原文直载）",
            "parentRegion": "海内南经（原文直载：隶属巴地）",
            "adjacentTiles": "丹山（原文直载：在其东），丹阳（地图推定：在丹山之北）",
            "relatedWaters": "未载（原文未载）",
            "relatedLife": "未载（原文未载）"
          },
