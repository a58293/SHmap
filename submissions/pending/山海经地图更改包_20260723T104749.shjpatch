        "dossier": {
          "format": "nine-section-v2",
          "sourceFile": "神明之丘.md",
          "sourceFiles": [
            "神明之丘.md"
          ],
          "profile": {
            "regionPosition": "海内中心丘陵水网地带（地图推定）",
            "oneLineSummary": "神民之丘是海内九座相连丘陵的第九座，四周被交织水系环绕，临近神树建木，属上古帝王神圣活动区域。",
            "briefSummary": "神民之丘是海内九座相连丘陵的第九座，四周被交织水系环绕，临近神树建木，属上古帝王神圣活动区域。",
            "basicSummary": "海内中心丘陵水网地带（地图推定）",
            "localTags": "九丘之一、水络交织、建木相邻、帝王遗迹、海内枢纽",
            "tileType": "丘陵（原文直载）",
            "hydrology": "被未命名水系环绕络结（原文直载）",
            "orientation": "海内区域（原文直载）",
            "sourceCitation": "《山海经·海内经》",
            "parentRegion": "海内经（原文直载）",
            "adjacentTiles": "陶唐之丘，有叔得之丘，孟盈之丘，昆吾之丘，黑白之丘，赤望之丘，参卫之丘，武夫之丘（原文直载）",
            "relatedWaters": "络九丘之水（未命名水系）（原文直载）",
            "relatedLife": "",
            "tileOriginalExcerpt": "“有九丘，以水络之：名曰……神民之丘。有木……名曰建木……大皞爰过，黄帝所为。”出自《山海经·海内经》。",
            "otherAllusions": "《尚书·序》载：“九州之志，谓之《九丘》”。（古注补充：晋代郭璞注及后世学者多推测此九丘与古史所载《九丘》同源或存在文化映射，具体地理方位待考。）",
            "detailedSummary": "神民之丘（原典多作神民之丘）位于《山海经·海内经》记载的海内区域，是“九丘水络”地理枢纽中位列第九的收尾丘陵。其地貌奇特，四周被未命名的水系如网状紧紧交织环绕（原文直载）。在空间分布上，它与武夫之丘、陶唐之丘等其余八座丘陵紧密毗邻。在这片水络交错的地带，伴生着青叶紫茎、百仞无枝的通天神树“建木”（地图推定）。典籍中虽未见此地的鸟兽与珍矿记载，但该区域神圣属性极高：上古神祇大皞曾途经这片水乡丘陵，黄帝也曾在此施展作为。神民之丘以其特殊的并列地貌与深厚的帝王遗迹，成为了海内核心区极具象征意义的重要地标。",
            "geoEnvironment": "海内中心丘陵水网地带（地图推定）\n丘陵（原文直载）\n被未命名水系环绕络结（原文直载）",
            "evidenceChain": "《山海经·海内经》\n《尚书·序》载：“九州之志，谓之《九丘》”。（古注补充：晋代郭璞注及后世学者多推测此九丘与古史所载《九丘》同源或存在文化映射，具体地理方位待考。）"
          },
