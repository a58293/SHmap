        "lockStatus": "与昆仑主体同地锁定；弱水环渊、炎火外层、西王母穴居为大荒外围层",
        "range": "以海内昆仑8×8格作为候选叠置范围；大荒本文未给面积",
        "terrain": "大山；弱水环山，外有炎火之山",
        "water": "位于赤水与黑水之间；弱水之渊环绕山体",
        "plants": "",
        "animals": "人面虎身、有文有尾的神",
        "minerals": "",
        "wildlife": "",
        "beasts": "",
        "people": "西王母",
        "gods": "昆仑山神；西王母居此",
