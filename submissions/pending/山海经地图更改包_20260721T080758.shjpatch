        "people": "烛光",
        "gods": "",
        "residents": "舜妻登比氏之女",
        "appearance": "",
        "abilities": "与宵明之灵照此所方百里",
        "events": "居河大泽",
        "original": "舜妻登比氏生宵明、燭光，處河大澤，二女之靈能照此所方百里。一曰登北氏。",
        "originalLink": "HYPERLINK(\"#'山海经原文总库'!A1950\",\"查看对应原文段落\")",
        "sameName": "本卷同句出现；暂无第二处独立地理条目。",
        "annotations": "",
        "otherTexts": "",
        "variants": "烛光／燭光",
        "modernResearch": "",
        "commonLocation": "",
        "popularSources": "",
        "misconceptions": "烛光与《大荒北经》烛龙、烛阴名称相近，但正文没有提供同一证据，不能合并。",
        "derivation": "V024将烛光作为河大泽内部人物对象独立建档，格内Δ(+30,-20)里只为排版。",
        "sourceUrl": "https://ctext.org/shan-hai-jing/hai-nei-bei-jing/zh\nhttps://zh.wikisource.org/zh-hans/山海經/海內北經",
        "geometryType": "point",
        "area": null,
        "path": null,
        "imageUrl": "",
        "regionIds": [
          "region-detail-dac42u"
        ],
        "primaryRegionId": "region-detail-dac42u",
