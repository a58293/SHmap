        "coordinateText": "X=0里，Y=0里（0，0格）",
        "name": "九丘",
        "type": "丘群／水网区域",
        "chapter": "《海内经》",
        "region": "都广00核心区／建木基座",
        "direction": "中央",
        "distance": 0,
        "originalHardDistance": "",
        "reference": "直接参照地：建木；都广之野\n原文方向：只说“以水络之”",
