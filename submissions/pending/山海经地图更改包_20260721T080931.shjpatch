        "dossier": {
          "format": "nine-section-v1",
          "sourceFile": "雁门山.md",
          "sourceFiles": [
            "雁门山.md"
          ],
          "profile": {
            "regionPosition": "海内北经区域（原文直载）",
            "oneLineSummary": "位于海内北部的一座山岳，是地理坐标序列中的重要参照点，与周边的地理环境构成了海内北经的拓扑结构，详细信息留白。",
            "briefSummary": "位于海内北部的一座山岳，是地理坐标序列中的重要参照点，与周边的地理环境构成了海内北经的拓扑结构，详细信息留白。",
            "basicSummary": "海内北经区域（原文直载）",
            "localTags": "海内北经、北部山岳、地理坐标、记录极简、方位锚点、拓扑节点",
            "tileOriginalExcerpt": "“雁门山，雁出其中。”出自《山海经·海内北经》（原文直载）。",
            "otherAllusions": "晋代郭璞注：“言雁之往来，由此山门也。”（古注补充）。后世地理志多与今山西代县之雁门关地理概念混淆，但在原典中，其仅作为北方山川的方位指代（现代研究参考）。",
            "detailedSummary": "在《山海经·海内北经》的地理叙事中，“雁门山”展现出一种高度抽象且克制的方位标记功能。原典仅以“雁出其中”四字，便赋予了该山作为迁徙通道的特性，将其锚定在海内北部的版图之上。除此之外，关于该山的具体地质形貌、覆盖植被、矿产储量及神异传说，原典均未作任何延展，呈现出彻底的地理留白。这种剥离了所有环境修饰的记述方式，使雁门山在《山海经》的空间模型中更像是一个纯粹的功能性坐标点，用于标定北方地理序列。它不仅真实反映了上古先民对北方山川与季节性生物迁徙现象的朴素认知，也为构建海内北经的地理拓扑结构提供了关键的方位支撑。在地图背调中，其核心价值在于锁定北方地理维度，而非提供具体的景观信息。",
            "geoEnvironment": "海内北经区域（原文直载）",
            "evidenceChain": "晋代郭璞注：“言雁之往来，由此山门也。”（古注补充）。后世地理志多与今山西代县之雁门关地理概念混淆，但在原典中，其仅作为北方山川的方位指代（现代研究参考）。"
          },
