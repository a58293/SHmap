{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "山海经原典地图研究台",
  "version": "0.6.1",
  "identifier": "art.tiphareth.shanhaijing.mapdesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "山海经原典地图研究台",
        "width": 1600,
        "height": 1000,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "maximized": true,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0REE0RjA4MDE4OTUzQTcKUldTblU0a0JDRS9hWkNxUG1acVBEWlNjZ1BZaWYwREZyZ3l4aHRmcXFaVTNsVnZabWlQMmVUUk0K",
      "endpoints": [
        "https://raw.githubusercontent.com/a58293/SHmap/main/updates/latest.json",
        "https://cdn.jsdelivr.net/gh/a58293/SHmap@main/updates/latest.json",
        "https://github.com/a58293/SHmap/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
