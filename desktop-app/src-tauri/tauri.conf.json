{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "山海经原典地图研究台",
  "version": "0.1.0",
  "identifier": "art.tiphareth.shanhaijing.mapdesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "山海经原典地图研究台",
        "width": 1600,
        "height": 1000,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "maximized": true,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
